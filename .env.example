# Reading Buddy environment variables

# disabled next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# Sarvam AI speech-to-text API key (required)
SARVAM_API_KEY=your_sarvam_api_key_here

# Groq API key (optional - for encouragement feedback)
GROQ_API_KEY=your_groq_api_key_here

# public app url
NEXT_PUBLIC_APP_URL=http://localhost:3000

# clerk auth keys (not used in MVP, kept for future)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxx

# neon db uri (not used in MVP, kept for future)
# DATABASE_URL="postgresql://user:password@host:port/db?sslmode=require"

# stripe api key and webhook (not used in MVP, kept for future)
# STRIPE_API_SECRET_KEY=sk_test_xxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx
